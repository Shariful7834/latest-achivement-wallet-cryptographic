# ── Dependencies ──────────────────────────────────
node_modules/

# ── Build output ──────────────────────────────────
academic-wallet/client/dist/

# ── Runtime data (regenerated on startup) ─────────
academic-wallet/data/db.json
academic-wallet/data/uploads/

# ── Secrets: ES256 issuer signing keys + revocation state (NEVER commit) ──
academic-wallet/data/keys/
academic-wallet/data/status/

# ── Local binaries / tunnels ─────────────────────
cloudflared.exe
*.exe

# ── Thesis docs / scratch scripts (not part of the app) ──
*.docx
THESIS_*.md
Thesis_*.md
thesis_structure.txt
certlister.txt
screenshot/
*.py

# ── Moodle core (only plugin is tracked) ─────────
moodle/*
!moodle/local/
moodle/local/*
!moodle/local/academic_wallet/

# ── Excluded projects ────────────────────────────
openbadges-specification/
moodle-docker/

# ── OS & editor files ────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/
.phpstorm.meta.php/

# ── Env files ────────────────────────────────────
.env
